# LLM Provider configuration
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Application
APP_ENV=development
LOG_LEVEL=DEBUG

# Microservices routing
ESTIMATION_SERVICE_URL=http://localhost:8001

# Asynchronous messaging (estimation-service)
RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=estimation.jobs
RABBITMQ_QUEUE=estimation.jobs.queue
RABBITMQ_ROUTING_KEY=estimation.requested
