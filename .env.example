# LLM Provider configuration
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Application
APP_ENV=development
LOG_LEVEL=DEBUG

# Microservices routing
ESTIMATION_SERVICE_URL=http://localhost:8001

# Asynchronous messaging (estimation-service)
RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=estimation.jobs
RABBITMQ_QUEUE=estimation.jobs.queue
RABBITMQ_ROUTING_KEY=estimation.requested
RABBITMQ_RETRY_EXCHANGE=estimation.jobs.retry
RABBITMQ_RETRY_QUEUE=estimation.jobs.retry.queue
RABBITMQ_DLQ_EXCHANGE=estimation.jobs.dlq
RABBITMQ_DLQ_QUEUE=estimation.jobs.dlq.queue
RABBITMQ_MAX_RETRIES=5
RABBITMQ_BASE_RETRY_DELAY_MS=1000

# Async job state persistence (estimation-service)
REDIS_URL=redis://localhost:6379/0
REDIS_JOB_KEY_PREFIX=estimation:job
OUTBOX_KEY_PREFIX=estimation:outbox
OUTBOX_DISPATCH_BATCH_SIZE=20
OUTBOX_DISPATCH_INTERVAL_SECONDS=1.0
