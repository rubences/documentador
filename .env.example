# ============================================================
# CONFIGURACIÓN DE SEGURIDAD - IMPORTANTE LEER
# ============================================================
# Este archivo contiene las variables de entorno con valores por defecto SEGUROS.
# En producción, CÁMBIAR todos los secretos y credenciales.

# ----------------------------------------------------------------
# Seguridad - Rate Limiting
# ----------------------------------------------------------------
# Límites por IP del cliente para prevenir abuso
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200

# ----------------------------------------------------------------
# Seguridad - Autenticación Interna
# ----------------------------------------------------------------
# ⚠️ IMPORTANTE: En producción, generar una nueva clave aleatoria
# comando: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Esta clave debe ser la MISMA en gateway y estimation-service
# para permitir comunicación interna
INTERNAL_API_KEY=changeme-in-production-generate-new-key
INTERNAL_AUTH_ENABLED=true

# ----------------------------------------------------------------
# Seguridad - CORS
# ----------------------------------------------------------------
# Lista de orígenes separados por coma. SOLO estos orígenes pueden acceder.
# En desarrollo: "http://localhost:3000,http://localhost:8080"
# En producción: configurar orígenes específicos de tu frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ----------------------------------------------------------------
# LLM Provider
# ----------------------------------------------------------------
# ⚠️ CONFIGURAR ESTAS CON CLAVES VÁLIDAS
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Validación de input
# Máximo de caracteres para transcripciones (~25k tokens)
TRANSCRIPTION_MAX_LENGTH=25000

# ----------------------------------------------------------------
# Aplicación
# ----------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=DEBUG

# ----------------------------------------------------------------
# Microservicios routing
# ----------------------------------------------------------------
ESTIMATION_SERVICE_URL=http://estimation-service:8001
GATEWAY_TIMEOUT_CONNECT_SECONDS=2.0
GATEWAY_TIMEOUT_READ_SECONDS=10.0
GATEWAY_TIMEOUT_WRITE_SECONDS=5.0
GATEWAY_TIMEOUT_POOL_SECONDS=2.0
GATEWAY_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
GATEWAY_CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=30.0
GATEWAY_CIRCUIT_BREAKER_HALF_OPEN_SUCCESS_THRESHOLD=2

# ----------------------------------------------------------------
# Asynchronous messaging (estimation-service)
# ----------------------------------------------------------------
# ⚠️ IMPORTANTE: CAMBIAR credenciales en producción
# NO usar guest:guest en producción
RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# Credenciales separadas (recomendado usar estas en producción)
RABBITMQ_USER=estimation_user
RABBITMQ_PASSWORD=changeme-strong-password-here
RABBITMQ_EXCHANGE=estimation.jobs
RABBITMQ_QUEUE=estimation.jobs.queue
RABBITMQ_ROUTING_KEY=estimation.requested
RABBITMQ_RETRY_EXCHANGE=estimation.jobs.retry
RABBITMQ_RETRY_QUEUE=estimation.jobs.retry.queue
RABBITMQ_DLQ_EXCHANGE=estimation.jobs.dlq
RABBITMQ_DLQ_QUEUE=estimation.jobs.dlq.queue
RABBITMQ_MAX_RETRIES=5
RABBITMQ_BASE_RETRY_DELAY_MS=1000

# ----------------------------------------------------------------
# Async job state persistence (estimation-service)
# ----------------------------------------------------------------
# TTL para jobs en Redis (por defecto 24 horas)
REDIS_URL=redis://localhost:6379/0
REDIS_JOB_KEY_PREFIX=estimation:job
REDIS_JOB_TTL_SECONDS=86400
OUTBOX_KEY_PREFIX=estimation:outbox
OUTBOX_DISPATCH_BATCH_SIZE=20
OUTBOX_DISPATCH_INTERVAL_SECONDS=1.0